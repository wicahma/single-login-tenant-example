SSO_BASE_URL=http://localhost:4000
CLIENT_ID=acc.one
CLIENT_SECRET=your-client-secret-here
NEXTAUTH_SECRET=your-nextauth-secret-here
NEXTAUTH_URL=http://localhost:3000

# encryption keys (NEXT_PUBLIC_ prefix required — used in the browser to encrypt request fields)
# will be the api_key in the manual authentication config
NEXT_PUBLIC_ENCRYPTION_SECRET_KEY=your-encryption-secret-key-here
# will be the key_id in the manual authentication config
NEXT_PUBLIC_ENCRYPTION_SALT_KEY=your-encryption-salt-key-here

# Manual Authentication Config
API_KEY=your-api-key
APP_IDENTIFIER=your-app-identifier
KEY_ID=your-key-id
PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----
your-private-key-here
-----END PRIVATE KEY-----"
